rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // School logos — admin write, public read
    match /schools/{schoolId}/logo {
      allow read:  if true;
      allow write: if request.auth != null;
    }
    // Invoices / documents — admin only
    match /invoices/{file} {
      allow read, write: if request.auth != null;
    }
  }
}
